# ─── LLM Provider ───
# Options: groq (free, fast), mistral, openai, ollama
LLM_PROVIDER=groq

# ─── API Configuration ───
# For groq: https://api.groq.com/openai
# For mistral: https://api.mistral.ai
# For openai: https://api.openai.com
# For ollama: http://friends-ip:11434
LLM_API_URL=https://api.groq.com/openai
LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
LLM_MODEL=llama-3.1-8b-instant

# ─── Embedding Provider ───
# ollama = use Ollama for embeddings | none = skip embeddings
EMBED_PROVIDER=none
EMBED_API_URL=http://localhost:11434
LLM_EMBED_MODEL=nomic-embed-text

# ─── Blog Generator Settings ───
POSTS_PER_CYCLE=3
SCHEDULE_INTERVAL_HOURS=2
TARGET_WORD_COUNT=1200

# ─── Logging ───
LOG_LEVEL=INFO
